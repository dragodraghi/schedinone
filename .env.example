VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_GAME_ID=schedinone-2026

# Optional: pre-fill API-Football key for the admin sync button.
# The admin can also paste it at runtime; it's saved to localStorage.
# Get a free key at https://dashboard.api-football.com/
VITE_FOOTBALL_API_KEY=

# Firebase Cloud Messaging VAPID public key (get it from Firebase Console > Project Settings > Cloud Messaging)
VITE_FCM_VAPID_KEY=
