rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{gameId} {
      allow read: if request.auth != null;
      // Existing admins can change any field.
      allow write: if request.auth != null
        && request.auth.uid in resource.data.admins;
      // Self-promotion: any authenticated user can add ONLY their own UID to
      // the admins array (the client validates the adminCode first). They
      // can't touch any other field and can't remove other admins.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['admins'])
        && request.auth.uid in request.resource.data.admins
        && request.resource.data.admins.hasAll(resource.data.admins)
        && request.resource.data.admins.size() == resource.data.admins.size() + 1;

      match /matches/{matchId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.admins;
      }

      match /players/{playerId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.uid == playerId;
        // Player can update own doc, but not points or paid
        // Player CAN set scheduleStatus only to "inviata"
        allow update: if request.auth != null
          && request.auth.uid == playerId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['points', 'paid'])
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['scheduleStatus'])
            || request.resource.data.scheduleStatus == 'inviata'
          );
        // Admins can update/delete any player
        allow update, delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.admins;
      }
    }
  }
}
