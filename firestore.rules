rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{gameId} {
      allow read: if request.auth != null;
      // Existing admins can change any field.
      allow write: if request.auth != null
        && request.auth.uid in resource.data.admins;
      // Self-promotion: any authenticated user can add ONLY their own UID to
      // the admins array (the client validates the adminCode first). They
      // can't touch any other field and can't remove other admins.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['admins'])
        && request.auth.uid in request.resource.data.admins
        && request.resource.data.admins.hasAll(resource.data.admins)
        && request.resource.data.admins.size() == resource.data.admins.size() + 1;

      match /matches/{matchId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.admins;
      }

      match /players/{playerId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.uid == playerId;
        // Player can update own doc, but not points or paid
        // Player CAN set scheduleStatus only to "inviata"
        allow update: if request.auth != null
          && request.auth.uid == playerId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['points', 'paid'])
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['scheduleStatus'])
            || request.resource.data.scheduleStatus == 'inviata'
          );
        // Admins can update/delete any player
        allow update, delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.admins;
      }

      match /announcements/{announcementId} {
        allow read: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.admins
          || (
            resource.data.status == 'published'
            && resource.data.deletedAt == null
            && (resource.data.targetUids == null || request.auth.uid in resource.data.targetUids)
          )
        );
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.admins
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 120
          && request.resource.data.body is string
          && request.resource.data.body.size() <= 2000
          && request.resource.data.status in ['draft', 'published']
          && (request.resource.data.targetUids == null || request.resource.data.targetUids is list);
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.admins
          && request.resource.data.title.size() <= 120
          && request.resource.data.body.size() <= 2000
          && (
            (resource.data.status == 'draft' && request.resource.data.status == 'published'
              && request.resource.data.publishedAt == request.time)
            || (resource.data.status == 'published' && request.resource.data.status == 'published'
              && request.resource.data.editedAt == request.time)
            || (resource.data.status == 'draft' && request.resource.data.status == 'draft')
            || (request.resource.data.deletedAt == request.time)
          );
        allow delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.admins;
      }

      match /threads/{playerUid} {
        allow read: if request.auth != null && (
          request.auth.uid == playerUid
          || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.admins
        );
        // Maintained only by Cloud Functions and the markThreadRead callable.
        allow write: if false;

        match /messages/{messageId} {
          allow read: if request.auth != null && (
            request.auth.uid == playerUid
            || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.admins
          );
          allow create: if request.auth != null
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 1000
            && request.resource.data.senderUid == request.auth.uid
            && (
              // Player in own thread with 2s rate limit (allowed if thread doesn't exist yet)
              (
                request.auth.uid == playerUid
                && request.resource.data.from == 'player'
                && (
                  !exists(/databases/$(database)/documents/games/$(gameId)/threads/$(playerUid))
                  || request.time > get(/databases/$(database)/documents/games/$(gameId)/threads/$(playerUid)).data.lastMessageAt + duration.value(2, 's')
                )
              )
              // Admin to any thread
              || (
                request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.admins
                && request.resource.data.from == 'committee'
              )
            );
          allow update, delete: if false;
        }
      }
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /fcmTokens/{token} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
