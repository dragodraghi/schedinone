rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{gameId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid in resource.data.admins;

      match /matches/{matchId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.admins;
      }

      match /players/{playerId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.uid == playerId;
        // Player can update own doc, but not points, paid, or scheduleStatus
        allow update: if request.auth != null
          && request.auth.uid == playerId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['points', 'paid', 'scheduleStatus']);
        // Admins can update any player (for paid toggle, removal, points)
        allow update, delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.admins;
      }
    }
  }
}
