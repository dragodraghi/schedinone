rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function gameDoc(gameId) {
      return get(/databases/$(database)/documents/games/$(gameId));
    }

    function isAdmin(gameId) {
      return isSignedIn()
        && request.auth.uid in gameDoc(gameId).data.admins;
    }

    function isLegacyClientMode(gameId) {
      return gameDoc(gameId).data.adminCode is string;
    }

    match /games/{gameId} {
      allow read: if isSignedIn();
      // Existing admins can change any field.
      allow write: if isAdmin(gameId);
      // Spark-compatible fallback: when the admin code is still public in the
      // game doc, let a player add only their own UID to admins.
      allow update: if isSignedIn()
        && resource.data.adminCode is string
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['admins'])
        && request.auth.uid in request.resource.data.admins
        && request.resource.data.admins.hasAll(resource.data.admins)
        && request.resource.data.admins.size() == resource.data.admins.size() + 1;

      match /matches/{matchId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(gameId);
      }

      match /players/{playerId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && isLegacyClientMode(gameId)
          && request.auth.uid == playerId
          && request.resource.data.keys().hasOnly([
            'name',
            'nameLower',
            'joinedAt',
            'predictions',
            'topScorerPick',
            'winnerPick',
            'points',
            'paid',
            'scheduleStatus'
          ])
          && request.resource.data.points == 0
          && request.resource.data.paid == false
          && request.resource.data.scheduleStatus == 'bozza';
        // Spark-compatible fallback: own schedina stays editable client-side
        // until the player sends it, while points and paid stay admin-only.
        allow update: if isSignedIn()
          && isLegacyClientMode(gameId)
          && request.auth.uid == playerId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['points', 'paid'])
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['scheduleStatus'])
            || request.resource.data.scheduleStatus == 'inviata'
          );
        // Admins can create/update/delete any player
        allow write: if isAdmin(gameId);
      }
    }
  }
}
